      "s": "editor::MoveDown",
    },
  },
  {
    "context": "ThreadsSidebar > Editor && VimControl && vim_mode == normal",
    "unbind": {
      "j": "editor::MoveDown",
    },
  },
  {
    "context": "GitPanel && ChangesList && !GitBranchSelector",
