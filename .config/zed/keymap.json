      "j": "settings_editor::FocusNextNavEntry",
    },
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "s": "vim::Down",
    },
  },
  {
    "context": "VimControl && !menu",
    "unbind": {
      "j": "vim::Down",
    },
  },
  {
