[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    },
  },
  {
    "context": "(vim_mode == helix_normal || vim_mode == helix_select) && !menu",
    "bindings": {
      "a": "vim::WrappingLeft",
    },
  },
  {
    "context": "(vim_mode == helix_normal || vim_mode == helix_select) && !menu",
    "unbind": {
      "h": "vim::WrappingLeft",
    },
  },
  {
    "context": "ThreadsSidebar && !Editor",
    "unbind": {
      "h": "menu::SelectParent",
    },
  },
  {
    "context": "OutlinePanel && not_editing",
    "unbind": {
      "h": "outline_panel::CollapseSelectedEntry",
    },
  },
  {
    "context": "ProjectPanel && not_editing",
    "unbind": {
      "h": "project_panel::CollapseSelectedEntry",
    },
  },
  {
    "context": "SettingsWindow > NavigationMenu && !search",
    "unbind": {
      "h": "settings_editor::CollapseNavEntry",
    },
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "a": "vim::WrappingLeft",
    },
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "a": "vim::WrappingLeft",
      "d": "vim::WrappingRight",
      "left": "vim::WrappingLeft",
      "right": "vim::WrappingRight",
    },
  },
  {
    "context": "VimControl && !menu",
    "unbind": {
      "h": "vim::Left",
    },
  },
  {
    "context": "ThreadsSidebar > Editor && VimControl && vim_mode == normal",
